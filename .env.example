# ─── Backend switch ──────────────────────────────────────────────────────────
# true / on  → Firebase Auth + Firestore
# false / off → MatuDB (base de datos actual)
VITE_USE_FIREBASE=true

# ─── Firebase (requerido si VITE_USE_FIREBASE=true) ──────────────────────────
# Obtén estos valores en: https://console.firebase.google.com → Configuración del proyecto
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── MatuDB (requerido si VITE_USE_FIREBASE=false) ───────────────────────────
# Obtén estos valores en tu panel de MatuDB
VITE_MATUDB_URL=https://db.matudb.com
VITE_MATUDB_PROJECT_ID=
VITE_MATUDB_API_KEY=

# ─── Pagos (PayMatuByte — siempre activo) ────────────────────────────────────
VITE_PAYMATUBYTE_URL=https://pay.matubyte.com
VITE_PAYMATUBYTE_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME=MatuCourse

# Chat: UID del instructor (Firebase Authentication). Obligatorio si no usas app_config/public.
# VITE_INSTRUCTOR_USER_ID=
